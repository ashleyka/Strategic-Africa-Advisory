# Environment Variables — Stratagem Africa Advisory
# =====================================================
# This file stores your secret credentials.
# NEVER share this file publicly or upload it to GitHub.
# Railway will have its own copy of these values set in its dashboard.

# -------------------------------------------------------
# DATABASE — Supabase PostgreSQL Connection
# Get these from: supabase.com → Your Project → Settings → Database
# -------------------------------------------------------
DATABASE_URL=your-supabase-connection-string-goes-here

# -------------------------------------------------------
# SUPABASE API KEYS (for admin dashboard)
# Get these from: supabase.com → Your Project → Settings → API
# -------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-goes-here

# -------------------------------------------------------
# EMAIL NOTIFICATIONS (Gmail App Password)
# Get from: myaccount.google.com/apppasswords
# -------------------------------------------------------
EMAIL_FROM=your-gmail@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_TO=your-notification-email@gmail.com

# -------------------------------------------------------
# ADMIN DASHBOARD PASSWORD
# Choose any password you want for your admin panel
# -------------------------------------------------------
ADMIN_PASSWORD=choose-a-strong-password-here

# -------------------------------------------------------
# SERVER
# -------------------------------------------------------
PORT=3000
NODE_ENV=production
